POSTGRES_USER=postgres
POSTGRES_PASSWORD=postgres
POSTGRES_DB=products
POSTGRES_PORT=5432

QDRANT_HTTP_PORT=6333
QDRANT_COLLECTION=products

# Ollama — локально (если нет INFERENCE_API_KEY)
OLLAMA_PORT=11434
OLLAMA_URL=http://localhost:11434
EMBED_MODEL=bge-m3
EMBEDDING_DIMENSION=1024
OLLAMA_MODEL=qwen2.5:3b-instruct
OLLAMA_TIMEOUT_SECONDS=600
OLLAMA_MAX_TOKENS=300

# Dockhost LLM Inference — без скачивания моделей (приоритет над Ollama)
# AI-Платформа → LLM инференс → Добавить API-ключ
INFERENCE_API_KEY=
INFERENCE_BASE_URL=https://inference.dockhost.io/v1
# EMBED_MODEL=qwen/qwen3-embedding-8b
# EMBEDDING_DIMENSION=4096
# INFERENCE_CHAT_MODEL=qwen/qwen3.5-9b
INFERENCE_TIMEOUT_SECONDS=120

BACKEND_PORT=8000

MOCK_MODE=false

# Локально с Ollama:
#   ollama pull bge-m3
#   ollama pull qwen2.5:3b-instruct
